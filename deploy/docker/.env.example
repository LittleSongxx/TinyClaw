COMPOSE_PROJECT_NAME=tinyclaw
TZ=Asia/Shanghai
APP_UID=1000
APP_GID=1000
APP_HOME=/app/data/home
XDG_CACHE_HOME=/app/data/.cache

HOST_HTTP_PORT_START=36060
HOST_ADMIN_PORT_START=18080
ENABLE_CLOUDFLARED=false
HF_EMBEDDINGS_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-1.9

# Gateway / Session / PC Node
GATEWAY_WS_PATH=/gateway/ws
GATEWAY_NODE_WS_PATH=/gateway/nodes/ws
GATEWAY_SHARED_SECRET=replace-with-a-strong-shared-secret
NODE_PAIRING_TOKEN=replace-with-a-strong-node-pairing-token
PRIVILEGED_USER_IDS=
SESSION_TRANSCRIPT_DIR=/app/data/sessions

BOT_NAME=TinyClawLark
LANG=zh
TYPE=aliyun
MEDIA_TYPE=aliyun
DEFAULT_MODEL=qwen-max
DB_TYPE=sqlite3
SESSION_KEY=replace-with-a-random-session-key
CHECK_BOT_SEC=10
LOG_LEVEL=info
TOKEN_PER_USER=100000
USE_TOOLS=true
EMBEDDING_TYPE=huggingface
EMBEDDING_BASE_URL=http://hf-embeddings:80
EMBEDDING_MODEL_ID=BAAI/bge-small-zh-v1.5
EMBEDDING_QUERY_INSTRUCTION=为这个句子生成表示以用于检索相关文章：
EMBEDDING_DIMENSIONS=512
VECTOR_DB_TYPE=milvus
MILVUS_URL=milvus:19530
SPACE=TinyClaw
CHUNK_SIZE=500
CHUNK_OVERLAP=50

POSTGRES_DB=tinyclaw
POSTGRES_USER=tinyclaw
POSTGRES_PASSWORD=tinyclawpass
POSTGRES_DSN=postgres://tinyclaw:tinyclawpass@postgres:5432/tinyclaw?sslmode=disable
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tinyclaw-knowledge
MINIO_USE_SSL=false
DEFAULT_KNOWLEDGE_BASE=default
DEFAULT_COLLECTION=default
KNOWLEDGE_AUTO_MIGRATE=true
RERANKER_BASE_URL=

QQ_APP_ID=
QQ_APP_SECRET=
LARK_APP_ID=
LARK_APP_SECRET=
ALIYUN_TOKEN=

AMAP_MAPS_API_KEY=
BOCHA_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=
