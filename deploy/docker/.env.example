COMPOSE_PROJECT_NAME=tinyclaw
TZ=Asia/Shanghai

HOST_HTTP_PORT_START=36060
HOST_ADMIN_PORT_START=18080
ENABLE_CLOUDFLARED=false

BOT_NAME=TinyClawLark
LANG=zh
TYPE=aliyun
MEDIA_TYPE=aliyun
DEFAULT_MODEL=qwen-max
DB_TYPE=sqlite3
SESSION_KEY=replace-with-a-random-session-key
CHECK_BOT_SEC=10
LOG_LEVEL=info
USE_TOOLS=true
EMBEDDING_TYPE=huggingface
EMBEDDING_BASE_URL=http://hf-embeddings:80
EMBEDDING_MODEL_ID=BAAI/bge-small-zh-v1.5
EMBEDDING_QUERY_INSTRUCTION=为这个句子生成表示以用于检索相关文章：
VECTOR_DB_TYPE=milvus
MILVUS_URL=milvus:19530
SPACE=TinyClaw

QQ_APP_ID=
QQ_APP_SECRET=
LARK_APP_ID=
LARK_APP_SECRET=
ALIYUN_TOKEN=
